// ============================================
// FICS Clone — Prisma 7 Schema
// 출처: docs/ANALYSIS.md (Vijob FICS 역공학 결과)
// 본 v1: SQLite (MVP) / v1.1: PostgreSQL 마이그레이션
// SQLite 제약: enum 미지원 → String + 주석 / JSON 미지원 → String 직렬화
// ============================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ============================================
// 매니저 (상담사)
// role: ADMIN | MANAGER | VIEWER
// ============================================
model Manager {
  id           String    @id @default(cuid())
  email        String    @unique // 로그인 아이디 (이메일/유저네임 모두 허용 — UI 라벨은 "아이디")
  name         String
  passwordHash String
  role         String    @default("MANAGER")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  rooms         ChatRoom[]
  notes         Note[]
  auditLogs     AuditLog[]
  statusChanges StatusHistory[]

  @@map("managers")
}

// ============================================
// 신청자 (외국인)
// status: PENDING | IN_PROGRESS | CONFIRMED | CANCELLED | UNCONFIRMED
// nationality: VN | NP | TW | RU | MN | MM | US | BD | LA | KR | TL | ETC
// preferredLanguage: KO_KR | VI_VN | NE_NP | ZH_TW | RU_RU | MN_MN | MY_MM | EN_US | BN_BD | LO_LA | PT_TL
// ============================================
model Applicant {
  id                String   @id @default(cuid())
  name              String
  nationality       String
  preferredLanguage String
  email             String?
  phone             String?
  visa              String?
  privacyConsent    Boolean  @default(false)
  thirdPartyConsent Boolean  @default(false)
  status            String   @default("PENDING")
  appliedPlanId     String?
  appliedAt         DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // 유입 추적 — Phase 5 (last-touch)
  // sourcePartnerId가 null이면 미상 (구버전 데이터). DIRECT는 별도 partner row.
  sourcePartnerId String?
  sourceCampaign  String?   // utm_campaign — 거래처 내 캠페인 분기
  sourceMedium    String?   // utm_medium — banner / sms / qr / video / etc
  sourceReferrer  String?   // HTTP referrer (랜딩 직전 URL)
  sourceLandedAt  DateTime? // 랜딩 시각 (가입 전환 시간 측정)

  // 첫 터치 (first-touch) — Phase 5.7
  // 처음 유입된 채널을 영구 쿠키로 기록해 가입 시 함께 저장
  // 마케팅 어트리뷰션: last-touch는 단기 캠페인, first-touch는 브랜드 임팩트
  firstTouchPartnerId String?
  firstTouchCampaign  String?
  firstTouchMedium    String?
  firstTouchLandedAt  DateTime?

  appliedPlan   Plan?           @relation(fields: [appliedPlanId], references: [id])
  sourcePartner Partner?        @relation("ApplicantSourcePartner", fields: [sourcePartnerId], references: [id])
  firstTouchPartner Partner?    @relation("ApplicantFirstTouchPartner", fields: [firstTouchPartnerId], references: [id])
  rooms         ChatRoom[]
  notes         Note[]
  statusHistory StatusHistory[]

  @@index([status])
  @@index([nationality])
  @@index([sourcePartnerId, appliedAt])
  @@index([firstTouchPartnerId, appliedAt])
  @@map("applicants")
}

// ============================================
// 요금제
// carrier: LGU+ | KT | SKT (멀티 통신사 확장 대비)
// ============================================
model Plan {
  id            String   @id @default(cuid())
  name          String
  carrier       String   @default("LGU+")
  monthlyFee    Int
  dataAllowance String?
  voiceMinutes  String?
  smsCount      String?
  commitment    String?  // "12개월" / "24개월" / "약정 없음" — Phase 5.6
  description   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  applicants Applicant[]

  @@map("plans")
}

// ============================================
// 거래처 (Partner) — 유입 채널 추적용 — Phase 5.1
// 정산/수수료 로직은 의도적으로 제외 (이 시스템 범위 밖)
// code:
//   - URL slug: /r/[code]?campaign=xxx&medium=banner
//   - 자동 생성(영문+숫자 짧은 코드) + 매니저가 수정 가능
//   - "DIRECT"는 자체광고용 reserved slug — 시드에서 자동 생성
// ============================================
model Partner {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  contact   String?
  memo      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applicants          Applicant[]      @relation("ApplicantSourcePartner")
  firstTouchApplicants Applicant[]     @relation("ApplicantFirstTouchPartner")
  clicks              PartnerClick[]

  @@map("partners")
}

// ============================================
// 거래처 클릭 raw 로그 — Phase 5.7
// /r/[code] 진입마다 1 row. 가입 전환율 = applicants count / clicks count
// 비활성/잘못된 코드도 originalCode에 그대로 저장 (poisoning 분석용)
// ============================================
model PartnerClick {
  id           String   @id @default(cuid())
  partnerId    String?  // 매칭된 partner.id (DIRECT 폴백 포함). null = unmatched (raw 분석)
  originalCode String   // 사용자가 친 raw code — partnerId와 다를 수 있음 (오타/폐기 코드)
  campaign     String?
  medium       String?
  referrer     String?
  ipHash       String?  // sha256(ip + salt) — 개인정보 직접 저장 X, 유니크 방문자 추정
  userAgent    String?
  sessionId    String?  // 쿠키 fics_session — 같은 세션 내 중복 클릭 묶음
  createdAt    DateTime @default(now())

  partner Partner? @relation(fields: [partnerId], references: [id])

  @@index([partnerId, createdAt])
  @@index([originalCode, createdAt])
  @@index([createdAt])
  @@map("partner_clicks")
}

// ============================================
// 채팅방
// ============================================
model ChatRoom {
  id            String    @id @default(cuid())
  applicantId   String
  managerId     String?
  isFavorite    Boolean   @default(false)
  unreadCount   Int       @default(0)
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  applicant Applicant @relation(fields: [applicantId], references: [id])
  manager   Manager?  @relation(fields: [managerId], references: [id])
  messages  Message[]

  @@index([managerId, lastMessageAt])
  @@index([applicantId])
  @@map("chat_rooms")
}

// ============================================
// ★ 메시지 (자동번역 핵심)
// senderType: APPLICANT | MANAGER | SYSTEM
// type: TEXT | IMAGE | VIDEO | FILE | VOICE | STICKER | SYSTEM | CARD
// language: KO_KR | RU_RU | VI_VN | ... (BCP-47 underscore variant)
// cardType: RESUME | HOUSING | PROFILE | VIDEO | PLAN | GENERIC
// ============================================
model Message {
  id       String  @id @default(cuid())
  roomId   String
  senderType String
  senderId String? // applicantId or managerId (senderType에 따라)
  type     String

  // TEXT — 자동번역의 본체
  originalText   String?
  language       String?
  translatedText String?

  // 미디어 (JSON 직렬화)
  attachments String? // [{url, name, size, mimeType, width?, height?}]

  // 카드
  cardType    String?
  cardPayload String? // JSON

  // 메타
  isRead    Boolean   @default(false)
  readAt    DateTime?
  // 수정/삭제 (Phase 5.8) — soft-delete 정책
  // editedAt: 매니저가 본문 수정 시 갱신
  // deletedAt: 삭제 시 set, originalText/translatedText/cardPayload null로 비움
  editedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime?

  room ChatRoom @relation(fields: [roomId], references: [id])

  @@index([roomId, createdAt])
  @@index([roomId, isRead])
  @@map("messages")
}

// ============================================
// 메모 (매니저가 신청자에 남기는 메모)
// ============================================
model Note {
  id          String    @id @default(cuid())
  applicantId String
  managerId   String
  content     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime?

  applicant Applicant @relation(fields: [applicantId], references: [id])
  manager   Manager   @relation(fields: [managerId], references: [id])

  @@index([applicantId])
  @@map("notes")
}

// ============================================
// 상태 변경 이력
// ============================================
model StatusHistory {
  id          String   @id @default(cuid())
  applicantId String
  managerId   String
  fromStatus  String
  toStatus    String
  reason      String?
  changedAt   DateTime @default(now())

  applicant Applicant @relation(fields: [applicantId], references: [id])
  manager   Manager   @relation(fields: [managerId], references: [id])

  @@index([applicantId, changedAt])
  @@map("status_history")
}

// ============================================
// 감사 로그 (★ Vijob엔 없는 우리만의 강점)
// action: MESSAGE_SENT | STATUS_CHANGED | DATA_VIEWED | LOGIN | LOGOUT | NOTE_CREATED | NOTE_UPDATED | NOTE_DELETED | ...
// ============================================
model AuditLog {
  id        String   @id @default(cuid())
  managerId String
  action    String
  resource  String
  metadata  String? // JSON
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  manager Manager @relation(fields: [managerId], references: [id])

  @@index([managerId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ============================================
// Outbox 패턴 (★ 메시지 손실 0 보장)
// 트랜잭션 안에서 outbox row 생성 → BullMQ 워커가 비동기 처리
// ============================================
model Outbox {
  id          String    @id @default(cuid())
  eventType   String // MESSAGE_CREATED | MESSAGE_UPDATED | STATUS_CHANGED | ROOM_JOINED | ...
  aggregateId String // roomId | applicantId
  payload     String // JSON
  processedAt DateTime?
  attempts    Int       @default(0)
  lastError   String?
  createdAt   DateTime  @default(now())

  @@index([processedAt, createdAt])
  @@map("outbox")
}

// ============================================
// 챗봇 플로우 (★ Vijob 미구현 — 우리 v2의 차별화)
// status: DRAFT | PUBLISHED | ARCHIVED
// trigger: 어떤 조건에서 이 플로우를 시작하는지 (예: "applicant.status=PENDING", "language=VI_VN")
// nodesData/edgesData: xyflow JSON 그대로 저장 (정규화는 추후 필요시)
// ============================================
model ChatbotFlow {
  id          String  @id @default(cuid())
  name        String
  description String?
  status      String  @default("DRAFT")
  trigger     String? // JSON — 트리거 조건 (Phase 4.4)

  // xyflow 상태 — Phase 4.1에선 직렬화된 JSON 저장
  nodesData String @default("[]")
  edgesData String @default("[]")

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("chatbot_flows")
}

// ============================================
// 번역 캐시 (Redis 백업용 영구 저장)
// 같은 메시지 ↔ 언어쌍 재번역 방지로 비용 절감
// ============================================
model TranslationCache {
  id             String   @id @default(cuid())
  contentHash    String   @unique // sha256(text + sourceLang + targetLang)
  sourceLanguage String
  targetLanguage String
  originalText   String
  translatedText String
  hits           Int      @default(0)
  createdAt      DateTime @default(now())
  lastUsedAt     DateTime @default(now())

  @@index([contentHash])
  @@map("translation_cache")
}
