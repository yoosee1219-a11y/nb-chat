# NB Chat 환경변수 템플릿
# 복사: cp .env.example .env
#
# 필수 항목은 ⭐ 표시.
# 실제 값은 절대 git commit 금지 (.gitignore에 .env* 등록됨).

# ============================================================
# DATABASE (필수) ⭐
# ============================================================
# 로컬 dev: SQLite 파일 (기본)
DATABASE_URL="file:./dev.db"

# 운영 (Vercel) — Turso 추천 (SQLite-as-a-service, 무료 9GB):
# DATABASE_URL="libsql://your-db-name-username.turso.io?authToken=eyJh..."
# 그 후 lib/prisma.ts에서 PrismaBetterSqlite3 → @libsql/client adapter로 교체

# 또는 PostgreSQL (Neon/Supabase):
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"


# ============================================================
# AUTH (필수) ⭐
# ============================================================
# JWT 서명용 32-byte 랜덤 base64.
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# 운영에선 secrets manager에 보관, dev/staging/prod 분리.
AUTH_SECRET="REPLACE_WITH_RANDOM_BASE64"


# ============================================================
# 자동번역 (선택) — Phase 3.4
# ============================================================
# Google Cloud Translate v2 REST — API 키 1개로 끝.
# 미설정 시 mock 번역 사용 (개발/테스트용 라벨링).
# https://cloud.google.com/translate/docs/setup
# GOOGLE_TRANSLATE_API_KEY="AIza..."

# 사용 안 함 (운영용 옵션):
# TRANSLATION_CACHE_DISABLED=false  # true로 두면 DB 캐시 우회 (디버그용)


# ============================================================
# LLM 챗봇 응답 (선택) — Phase 3.4
# ============================================================
# 모델명에 따라 자동 라우팅:
#   claude-* → Anthropic, gpt-* → OpenAI
# 미설정 시 mock 응답.
# ANTHROPIC_API_KEY="sk-ant-..."
# OPENAI_API_KEY="sk-..."


# ============================================================
# Socket.IO standalone 서버 (Phase 3.2+4.4)
# ============================================================
# 로컬: localhost:4001
SOCKET_PORT=4001
SOCKET_ALLOWED_ORIGINS="http://localhost:3000"

# 클라이언트가 연결할 소켓 URL. 운영에선 별도 호스팅 도메인 (Railway/Render/Fly.io)
NEXT_PUBLIC_SOCKET_URL="http://localhost:4001"


# ============================================================
# 향후 확장 (현재 미사용)
# ============================================================
# Redis (멀티노드 broadcast / Outbox 큐)
# REDIS_URL="redis://localhost:6379"
